# Anthropic API key — enables photo import (vision), URL fallback for sites
# without structured data, and AI suggestions for steps the rules can't map.
# The rules-based conversion works without it; these features degrade gracefully.
ANTHROPIC_API_KEY=

# Optional: override the model (vision-capable). Defaults to claude-sonnet-4-6.
LLM_MODEL=claude-sonnet-4-6
