# AI features (photo import, URL fallback for sites without structured data,
# and AI suggestions for steps the rules can't map). The rules-based conversion
# and URL import work WITHOUT any of this — these just unlock the extras.
#
# Defaults target the Vercel AI Gateway (https://ai-gateway.vercel.sh/v1) for
# native usage observability + spend caps. Create a key in the Vercel dashboard
# (AI Gateway → API Keys). Any OpenAI-compatible gateway works via AI_BASE_URL.

AI_GATEWAY_API_KEY=

# Optional overrides:
# AI_BASE_URL=https://ai-gateway.vercel.sh/v1
# AI_MODEL=anthropic/claude-haiku-4.5   # cheap + vision-capable; bump to
#                                       # anthropic/claude-sonnet-4.5 for headroom
#
# To use a different gateway instead (e.g. opencode Zen), set:
# AI_BASE_URL=https://opencode.ai/zen/v1
# AI_MODEL=claude-haiku-4-5
# OPENCODE_ZEN_API_KEY=...
